{

  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src","src/types/**/*.d.ts"],
  "exclude": ["node_modules","dist","test"]
}